# === CRITICAL: Bot Tokens (NEVER commit actual tokens!) ===
# Get your tokens from:
# User Bot: https://t.me/BotFather -> /newbot
# Admin Bot: https://t.me/BotFather -> /newbot
USER_BOT_TOKEN=YOUR_USER_BOT_TOKEN_HERE
ADMIN_BOT_TOKEN=YOUR_ADMIN_BOT_TOKEN_HERE

# === DATABASE CONFIGURATION ===
# For Railway, use PostgreSQL (more reliable than SQLite for production)
# Railway will automatically set DATABASE_URL, but you can override if needed
#
# SQLite (Development only - NOT for production)
# DATABASE_URL=sqlite+aiosqlite:///./data/vpn_store.db
#
# PostgreSQL (Production - Railway automatic)
# DATABASE_URL is automatically set by Railway for PostgreSQL plugin
# Format: postgresql+asyncpg://username:password@host:port/database
#
# Manual PostgreSQL (if not using Railway plugin)
# DATABASE_URL=postgresql+asyncpg://vpnbot_user:secure_password@localhost:5432/vpnbot_db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpnbot

# === ENVIRONMENT ===
# Options: development, staging, production
ENVIRONMENT=production

# === LOGGING ===
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# === FILE STORAGE ===
# Local storage for development
# For production, consider using S3, GCS, or Railway's volume storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# === S3/MinIO CONFIGURATION (Optional - for future scaling) ===
# Uncomment to enable S3 storage instead of local
# STORAGE_TYPE=s3
# S3_BUCKET_NAME=vpn-bot-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
# S3_SECRET_KEY=YOUR_AWS_SECRET_KEY

# === CACHE CONFIGURATION ===
# Enable in-memory caching for Settings and Messages
ENABLE_CACHE=true
CACHE_TTL_SECONDS=300

# === TRANSACTION CONFIGURATION ===
# Enable atomic transactions for database operations
ENABLE_TRANSACTIONS=true

# === RAILWAY-SPECIFIC VARIABLES ===
# These are automatically set by Railway, but listed for reference:
# RAILWAY_ENVIRONMENT_NAME - Environment name (e.g., production)
# RAILWAY_SERVICE_NAME - Service name
# PORT - Exposed port (if using web service)
