# === Bot Tokens (CRITICAL - KEEP SECURE!) ===
USER_BOT_TOKEN=YOUR_USER_BOT_TOKEN_HERE
ADMIN_BOT_TOKEN=YOUR_ADMIN_BOT_TOKEN_HERE

# === DATABASE ===
# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./data/vpn_store.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/vpnbot

# === ENVIRONMENT ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === FILE STORAGE ===
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# === S3/MinIO (Optional) ===
# S3_BUCKET_NAME=vpn-bot
# S3_REGION=us-east-1
# S3_ACCESS_KEY=YOUR_KEY
# S3_SECRET_KEY=YOUR_SECRET

# === CACHE ===
ENABLE_CACHE=true
CACHE_TTL_SECONDS=300

# === TRANSACTIONS ===
ENABLE_TRANSACTIONS=true
